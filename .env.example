HOST=0.0.0.0
PORT=8016
BASE_URL=http://localhost:8016
ENV=development

# Optional inbound static bearer auth for /mcp
API_KEY=

# Optional Google OAuth for MCP caller auth
# Authorized redirect URI: {BASE_URL}/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAINS=
ALLOWED_EMAILS=

FASTMCP_STATELESS_HTTP=true

# Required for Infura-backed feeds in feeds.json unless using RPC_URL_<CHAIN> overrides
INFURA_API_KEY=

# Optional per-chain RPC overrides
# RPC_URL_ETHEREUM=
# RPC_URL_BASE=
